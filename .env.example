# ── Copy this to .env and fill in your values ────────────────────────────────

# vLLM endpoint (SSH tunnel or direct RunPod URL). Pod default port is 8002
# (see scripts/start_vllm.sh). Example tunnel:
#   ssh -L 8002:localhost:8002 -L 8000:localhost:8000 <pod-alias>
VLLM_BASE_URL=http://localhost:8002

# Model currently loaded in vLLM on the pod.
# Options:
#   google/gemma-3-27b-it
#   AbderrahmanSkiredj1/GemMaroc-27b-it
#   BounharAbdelaziz/Atlas-Chat-27B
VLLM_MODEL_NAME=gemma4-26b-it

# vLLM API key — leave blank if vLLM was started without --api-key
VLLM_API_KEY=

# SQLite database path (created automatically)
INTERACTIONS_DB_PATH=data/interactions.db

# Auth passwords — generate strong random values; never commit real secrets to git.
USER_SITE_PASSWORD=replace-with-strong-random
ADMIN_SITE_PASSWORD=replace-with-strong-random
SESSION_SECRET_KEY=replace-with-a-long-random-string

# Allowed frontend origins (comma-separated)
FRONTEND_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000

# Generation settings
MAX_NEW_TOKENS=2048
TEMPERATURE=0.7
TOP_P=0.9

# Reserve context budget for long conversation history (admin docs manager enforces it)
RAG_INJECT_MAX_CHARS=60000
RAG_CHAT_HISTORY_RESERVE_CHARS=12000

# Agentic RAG (optional test): POST /chat with "agentic_rag": true — see project/AGENTIC_RAG_TEST.md
# AGENTIC_RAG_ENABLED=false
# AGENTIC_RAG_ALLOW_NON_ADMIN=false
# AGENTIC_RAG_MAP_DIR=data/agentic_map
# AGENTIC_RAG_TEMPERATURE=0.35
# AGENTIC_RAG_USE_EMBEDDINGS=true
# AGENTIC_RAG_EMBEDDING_MODEL=intfloat/multilingual-e5-large
# AGENTIC_RAG_EMBEDDING_DEVICE=
# AGENTIC_MAP_EXTRACTION_MODEL=
