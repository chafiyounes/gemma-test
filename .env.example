# ── Copy this to .env and fill in your values ────────────────────────────────

# vLLM endpoint (SSH tunnel or direct RunPod URL). Pod default port is 8002
# (see scripts/start_vllm.sh). Example tunnel:
#   ssh -L 8002:localhost:8002 -L 8000:localhost:8000 <pod-alias>
VLLM_BASE_URL=http://localhost:8002

# Model currently loaded in vLLM on the pod.
# Options:
#   google/gemma-3-27b-it
#   AbderrahmanSkiredj1/GemMaroc-27b-it
#   BounharAbdelaziz/Atlas-Chat-27B
VLLM_MODEL_NAME=gemma4-26b-it

# vLLM API key — leave blank if vLLM was started without --api-key
VLLM_API_KEY=

# SQLite database path (created automatically)
INTERACTIONS_DB_PATH=data/interactions.db

# Auth passwords — generate strong random values; never commit real secrets to git.
USER_SITE_PASSWORD=replace-with-strong-random
ADMIN_SITE_PASSWORD=replace-with-strong-random
SESSION_SECRET_KEY=replace-with-a-long-random-string

# Optional: create staff accounts on first API startup if these usernames do not exist yet
# (see core/persistence.py _seed_named_staff). Use strong random passwords.
# SEED_STAFF_YOUNES_PASSWORD=
# SEED_STAFF_NOUHAILA_PASSWORD=
# Set to true temporarily if you need to overwrite those users' hashes from env (then turn off).
# SEED_STAFF_SYNC_PASSWORDS=false
#
# Or manage users directly (no redeploy): bash scripts/manage_users.sh list

# Allowed frontend origins (comma-separated)
FRONTEND_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000

# Generation settings
MAX_NEW_TOKENS=2048
TEMPERATURE=0.7
TOP_P=0.9
# When the model stops mid-answer (vLLM finish_reason=length), API may request up to
# VLLM_MAX_CONTINUE_ROUNDS short continuation turns. Tune VLLM_CONTINUE_MAX_TOKENS if needed.
# VLLM_MAX_CONTINUE_ROUNDS=5
# VLLM_CONTINUE_MAX_TOKENS=2048

# Must match vLLM --max-model-len on the pod. Used to cap RAG inject size.
# LLM_MAX_CONTEXT_TOKENS=16384

# RAG: BM25 unless corpus is small (see RAG_FULL_CATEGORY_* in app_config/settings.py)
# Hard ceiling; effective inject size is min(this, context budget — see core/llm.py).
RAG_INJECT_MAX_CHARS=22000
RAG_CHAT_HISTORY_RESERVE_CHARS=12000
# If false, skip the optional second vLLM call when the model claims "not in docs" despite a large inject.
# RAG_REPAIR_ENABLED=true
# LANGUAGE_REPAIR_ENABLED=true

# Case brief: one extra vLLM call before retrieval (understand → retrieve → answer). Off by default.
# CASE_BRIEF_ENABLED=false
# CASE_BRIEF_TEMPERATURE=0.15
# CASE_BRIEF_MAX_TOKENS=512
# REASONING_REPAIR_ENABLED=true

# Grounded deduction + per-thread memory (session_id). help_md = FAQ/help articles.
# GROUNDED_DEDUCTION_ENABLED=true
# THREAD_MEMORY_ENABLED=true
# THREAD_MEMORY_MAX_STATED_FACTS=16
# THREAD_MEMORY_MAX_DERIVED_FACTS=12
# RAG_EXTRA_CATEGORIES=help_md,help_articles
# RAG_FULL_CATEGORY_MAX_CHARS=72000
# RAG_FULL_CATEGORY_MAX_FILES=10

# Single corpus folder + default /chat category when clients omit category. Admin bulk
# uploads with an empty category field land here (catalog / agentic use the same name).
# RAG_DEFAULT_CATEGORY=procedures

# Agentic RAG (optional): POST /chat with "agentic_rag": true — see project/ARCHITECTURE.md
# AGENTIC_RAG_ENABLED=false
# When true, clients may omit agentic_rag; non-admin still needs AGENTIC_RAG_ALLOW_NON_ADMIN or classic RAG is used.
# AGENTIC_RAG_DEFAULT_ON_CHAT=false
# AGENTIC_RAG_ALLOW_NON_ADMIN=false
# When true, scope "all" / multi-category chat uses catalog router (requires AGENTIC_RAG_ENABLED=true).
# AGENTIC_RAG_ON_MULTI_SCOPE=true
# AGENTIC_RAG_CATALOG_NARROW_MAX=40
# AGENTIC_RAG_MAP_DIR=data/agentic_map
# AGENTIC_RAG_TEMPERATURE=0.35
# AGENTIC_RAG_USE_EMBEDDINGS=true
# AGENTIC_RAG_EMBEDDING_MODEL=intfloat/multilingual-e5-large
# AGENTIC_RAG_EMBEDDING_DEVICE=
# AGENTIC_MAP_EXTRACTION_MODEL=
# Router (two-phase): ~5 docs target, up to 10 total, 5 ids per tool call, 3 rounds
# AGENTIC_RAG_ROUTER_TARGET_DOCS=5
# AGENTIC_RAG_ROUTER_MAX_TOTAL_IDS=10
# AGENTIC_RAG_ROUTER_MAX_IDS_PER_ROUND=5
# AGENTIC_RAG_ROUTER_MAX_ROUNDS=3

# API diagnostics: if true, generic 500 JSON includes exception type + message (disable after debugging).
# API_EXPOSE_ERROR_DETAIL=false

# RunPod SSH (laptop → pod). Username from RunPod Connect tab; set in .env (not committed).
# RunPod (set after every pod reset — Connect tab)
# RUNPOD_SSH_HOST=ssh.runpod.io
# RUNPOD_SSH_USER=dvy5w58nwyz155-64411299
# RUNPOD_SSH_KEY=C:\Users\you\.ssh\id_ed25519
# RUNPOD_POD_ID=dvy5w58nwyz155
# Public UI when HTTP port 8000 is exposed (§0 in project/DEPLOYMENT.md):
# RUNPOD_PROXY_URL=https://dvy5w58nwyz155-8000.proxy.runpod.net
#
# Direct TCP SSH (required for local port tunnel — gateway ssh.runpod.io does not support -L):
# RUNPOD_DIRECT_HOST=194.68.x.x
# RUNPOD_DIRECT_PORT=22144
# Local UI after: python scripts/start_tunnel.py  ->  http://localhost:8000
